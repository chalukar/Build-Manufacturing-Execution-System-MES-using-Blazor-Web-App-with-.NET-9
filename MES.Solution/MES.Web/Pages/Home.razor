@page "/"
@inject WorkOrderService WorkOrderService
<PageTitle>MES — Manufacturing Execution System</PageTitle>

<div class="container-fluid py-4">

    @* Header *@
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-semibold">Dashboard</h2>
            <p class="text-muted mb-0">
                Manufacturing Execution System — Overview
            </p>
        </div>
        <div class="col-auto">
            <span class="text-muted small">
                @DateTime.Now.ToString("dddd, dd MMMM yyyy")
            </span>
        </div>
    </div>

    @* KPI Cards *@
    <div class="row g-3 mb-4">
        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10
                                d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;flex-shrink:0">
                        <span style="font-size:22px"></span>
                    </div>
                    <div>
                        <div class="text-muted small">Total Work Orders</div>
                        <div class="fs-4 fw-semibold">@_stats.TotalWorkOrders</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10
                                d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;flex-shrink:0">
                        <span style="font-size:22px"></span>
                    </div>
                    <div>
                        <div class="text-muted small">In Progress</div>
                        <div class="fs-4 fw-semibold text-success">
                            @_stats.InProgress
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-warning bg-opacity-10
                                d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;flex-shrink:0">
                        <span style="font-size:22px"></span>
                    </div>
                    <div>
                        <div class="text-muted small">Released</div>
                        <div class="fs-4 fw-semibold text-warning">
                            @_stats.Released
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-info bg-opacity-10
                                d-flex align-items-center justify-content-center"
                         style="width:52px;height:52px;flex-shrink:0">
                        <span style="font-size:22px"></span>
                    </div>
                    <div>
                        <div class="text-muted small">Completed Today</div>
                        <div class="fs-4 fw-semibold text-info">
                            @_stats.CompletedToday
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Quick Actions *@
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-semibold border-bottom">
                    Quick Actions
                </div>
                <div class="card-body d-flex flex-wrap gap-2">
                    <a href="/workorders/create" class="btn btn-primary">
                        + New Work Order
                    </a>
                    <a href="/workorders" class="btn btn-outline-primary">
                        View All Work Orders
                    </a>
                    <a href="/workcentres" class="btn btn-outline-secondary">
                        Work Centres
                    </a>
                    <a href="/quality" class="btn btn-outline-success">
                        Quality Inspections
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* Recent Work Orders *@
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent fw-semibold border-bottom
                             d-flex justify-content-between align-items-center">
                    <span>Recent Work Orders</span>
                    <a href="/workorders" class="btn btn-sm btn-outline-primary">
                        View All
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (_isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm text-primary"
                                 role="status"></div>
                            <span class="ms-2 text-muted">Loading...</span>
                        </div>
                    }
                    else if (_loadError is not null)
                    {
                        <div class="alert alert-warning m-3">
                            @_loadError —
                            <button class="btn btn-sm btn-link p-0"
                                    @onclick="LoadDataAsync">
                                Retry
                            </button>
                        </div>
                    }
                    else if (_recentWorkOrders.Count == 0)
                    {
                        <div class="text-center py-4 text-muted">
                            <p>No work orders yet.</p>
                            <a href="/workorders/create" class="btn btn-primary btn-sm">
                                Create your first work order
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>WO Number</th>
                                        <th>Product</th>
                                        <th>Work Centre</th>
                                        <th>Status</th>
                                        <th>Efficiency</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var wo in _recentWorkOrders)
                                    {
                                        <tr>
                                            <td class="fw-semibold">
                                                @wo.WorkOrderNumber
                                            </td>
                                            <td>@wo.ProductName</td>
                                            <td>@wo.WorkCentreName</td>
                                            <td>
                                                <span class="badge @GetStatusClass(wo.Status)">
                                                    @wo.Status
                                                </span>
                                            </td>
                                            <td>
                                                <div class="progress"
                                                     style="min-width:80px;height:6px">
                                                    <div class="progress-bar
                                                                 @GetProgressClass(wo.EfficiencyPercent)"
                                                         style="width:@(Math.Min(wo.EfficiencyPercent, 100))%">
                                                    </div>
                                                </div>
                                                <small class="text-muted">
                                                    @wo.EfficiencyPercent.ToString("N1")%
                                                </small>
                                            </td>
                                            <td>
                                                <a href="/workorders/@wo.Id"
                                                   class="btn btn-sm btn-outline-primary">
                                                    View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<WorkOrderDto> _recentWorkOrders = [];
    private DashboardStats _stats = new();
    private bool _isLoading = true;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
        => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var workOrders = await WorkOrderService.GetAllAsync();

            _recentWorkOrders = (workOrders ?? [])
                .OrderByDescending(x => x.PlannedStartDate)
                .Take(10)
                .ToList();

            // Calculate KPIs from the loaded data
            _stats = new DashboardStats
            {
                TotalWorkOrders = _recentWorkOrders.Count,
                InProgress = _recentWorkOrders
                                    .Count(x => x.Status == WorkOrderStatus.InProgress),
                Released = _recentWorkOrders
                                    .Count(x => x.Status == WorkOrderStatus.Released),
                CompletedToday = _recentWorkOrders
                                    .Count(x => x.Status == WorkOrderStatus.Completed
                                             && x.PlannedEndDate.Date == DateTime.Today)
            };
        }
        catch (Exception ex)
        {
            _loadError = $"Could not load dashboard data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string GetStatusClass(WorkOrderStatus s) => s switch
    {
        WorkOrderStatus.Draft => "bg-secondary",
        WorkOrderStatus.Released => "bg-info text-dark",
        WorkOrderStatus.InProgress => "bg-primary",
        WorkOrderStatus.Completed => "bg-success",
        WorkOrderStatus.Cancelled => "bg-danger",
        WorkOrderStatus.OnHold => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private static string GetProgressClass(decimal pct) => pct switch
    {
        >= 100 => "bg-success",
        >= 75 => "bg-info",
        >= 50 => "bg-warning",
        _ => "bg-danger"
    };

    private class DashboardStats
    {
        public int TotalWorkOrders { get; set; }
        public int InProgress { get; set; }
        public int Released { get; set; }
        public int CompletedToday { get; set; }
    }
}