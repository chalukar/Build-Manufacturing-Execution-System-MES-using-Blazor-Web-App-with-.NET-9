@page "/workorders/create"
@inject WorkOrderService WorkOrderService
@inject WorkCentreService WorkCentreService
@inject NavigationManager Nav

<PageTitle>New Work Order — MES</PageTitle>

<div class="d-flex align-items-center mb-4">
    <button class="btn btn-outline-secondary me-3"
            @onclick="@(() => Nav.NavigateTo("/workorders"))">
        &larr; Back
    </button>
    <h3 class="mb-0">New Work Order</h3>
</div>

@* Show API/network errors *@
@if (_loadError is not null)
{
    <div class="alert alert-danger">
        <strong>Could not load work centres:</strong> @_loadError
        <br />
        <button class="btn btn-sm btn-outline-danger mt-2"
                @onclick="LoadWorkCentresAsync">
            Retry
        </button>
    </div>
}

@* Show submit errors *@
@if (_errorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible">
        @_errorMessage
        <button type="button" class="btn-close"
                @onclick="@(() => _errorMessage = null)">
        </button>
    </div>
}

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Loading work centres...</p>
    </div>
}
else if (_loadError is null)
{
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Work Order Details</h5>
                </div>
                <div class="card-body">
                    <EditForm Model="_model" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />

                        @* Product Code *@
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Product Code <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                       @bind-Value="_model.ProductCode"
                                       placeholder="e.g. PROD-001" />
                            <ValidationMessage For="@(() => _model.ProductCode)"
                                               class="text-danger small" />
                        </div>

                        @* Product Name *@
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Product Name <span class="text-danger">*</span>
                            </label>
                            <InputText class="form-control"
                                       @bind-Value="_model.ProductName"
                                       placeholder="e.g. Widget A" />
                            <ValidationMessage For="@(() => _model.ProductName)"
                                               class="text-danger small" />
                        </div>

                        @* Work Centre *@
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Work Centre <span class="text-danger">*</span>
                            </label>
                            @if (_workCentres.Count == 0)
                            {
                                <div class="alert alert-warning">
                                    No active work centres found.
                                    <a href="/workcentres/create">Create one first.</a>
                                </div>
                            }
                            else
                            {
                                <InputSelect class="form-select"
                                             @bind-Value="_model.WorkCentreId">
                                    <option value="@Guid.Empty">
                                        — Select Work Centre —
                                    </option>
                                    @foreach (var wc in _workCentres)
                                    {
                                        <option value="@wc.Id">
                                            @wc.Name (@wc.Code)
                                        </option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => _model.WorkCentreId)"
                                                   class="text-danger small" />
                            }
                        </div>

                        @* Planned Quantity *@
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Planned Quantity <span class="text-danger">*</span>
                            </label>
                            <InputNumber class="form-control"
                                         @bind-Value="_model.PlannedQuantity"
                                         placeholder="0" />
                            <ValidationMessage For="@(() => _model.PlannedQuantity)"
                                               class="text-danger small" />
                        </div>

                        @* Dates *@
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    Planned Start Date <span class="text-danger">*</span>
                                </label>
                                <InputDate class="form-control"
                                           @bind-Value="_model.PlannedStartDate" />
                                <ValidationMessage For="@(() => _model.PlannedStartDate)"
                                                   class="text-danger small" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">
                                    Planned End Date <span class="text-danger">*</span>
                                </label>
                                <InputDate class="form-control"
                                           @bind-Value="_model.PlannedEndDate" />
                                <ValidationMessage For="@(() => _model.PlannedEndDate)"
                                                   class="text-danger small" />
                            </div>
                        </div>

                        @* Notes *@
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Notes</label>
                            <InputTextArea class="form-control"
                                           @bind-Value="_model.Notes"
                                           rows="3"
                                           placeholder="Optional notes..." />
                            <ValidationMessage For="@(() => _model.Notes)"
                                               class="text-danger small" />
                        </div>

                        @* Buttons *@
                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-primary"
                                    disabled="@(_isSubmitting || _workCentres.Count == 0)">
                                @if (_isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"
                                          role="status"></span>
                                    <span>Saving...</span>
                                }
                                else
                                {
                                    <span>Save Work Order</span>
                                }
                            </button>

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    @onclick="@(() => Nav.NavigateTo("/workorders"))"
                                    disabled="@_isSubmitting">
                                Cancel
                            </button>
                        </div>

                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private CreateWorkOrderModel _model = new();
    private List<WorkCentreDto> _workCentres = [];
    private string? _errorMessage;
    private string? _loadError;
    private bool _isLoading = true;
    private bool _isSubmitting;

    protected override async Task OnInitializedAsync()
    {
        _model.PlannedStartDate = DateTime.Today;
        _model.PlannedEndDate = DateTime.Today.AddDays(7);
        await LoadWorkCentresAsync();
    }

    private async Task LoadWorkCentresAsync()
    {
        _isLoading = true;
        _loadError = null;

        var (data, error) = await WorkCentreService.GetAllAsync();

        _workCentres = data;
        _loadError = error;
        _isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var dto = new CreateWorkOrderDto(
                _model.ProductCode.Trim(),
                _model.ProductName.Trim(),
                _model.PlannedQuantity,
                _model.PlannedStartDate,
                _model.PlannedEndDate,
                _model.WorkCentreId,
                string.IsNullOrWhiteSpace(_model.Notes)
                    ? null
                    : _model.Notes.Trim());

            var id = await WorkOrderService.CreateAsync(dto);

            if (id.HasValue)
                Nav.NavigateTo($"/workorders/{id.Value}");
            else
                _errorMessage = "Failed to create work order. Please try again.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private class CreateWorkOrderModel
    {
        [Required(ErrorMessage = "Product code is required.")]
        [MaxLength(50, ErrorMessage = "Product code cannot exceed 50 characters.")]
        public string ProductCode { get; set; } = string.Empty;

        [Required(ErrorMessage = "Product name is required.")]
        [MaxLength(200, ErrorMessage = "Product name cannot exceed 200 characters.")]
        public string ProductName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Work centre is required.")]
        [NotEmptyGuid(ErrorMessage = "Please select a work centre.")]
        public Guid WorkCentreId { get; set; } = Guid.Empty;

        [Range(1, double.MaxValue,
            ErrorMessage = "Planned quantity must be greater than zero.")]
        public decimal PlannedQuantity { get; set; }

        [Required(ErrorMessage = "Start date is required.")]
        public DateTime PlannedStartDate { get; set; }

        [Required(ErrorMessage = "End date is required.")]
        [DateGreaterThan(nameof(PlannedStartDate),
            ErrorMessage = "End date must be after start date.")]
        public DateTime PlannedEndDate { get; set; }

        [MaxLength(1000, ErrorMessage = "Notes cannot exceed 1000 characters.")]
        public string? Notes { get; set; }
    }
}